{
  "manifest_version": 3,
  "name": "Leads by SBL",
  "version": "2.0.0",
  "description": "LinkedIn lead search extension for LeadGen Pro",
  "permissions": [
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://www.dice.com/*",
    "https://www.workatastartup.com/*",
    "https://*.algolia.net/*",
    "https://www.google.com/*",
    "https://wellfound.com/*",
    "https://google.serper.dev/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Leads by SBL"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:*/*",
        "https://*.trycloudflare.com/*",
        "http://3.86.220.212:*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:*/*",
      "https://*.trycloudflare.com/*"
    ]
  }
}
